{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gemigo.io/schema/gemigo.app.schema.json",
  "title": "GemiGo Static App Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "visibility",
    "category",
    "tags",
    "defaultLocale",
    "locales"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "sourceDir": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "visibility": {
      "type": "string",
      "enum": ["public", "private"]
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaultLocale": {
      "type": "string",
      "minLength": 2
    },
    "locales": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
